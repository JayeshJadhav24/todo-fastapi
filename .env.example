# .env.example — Template for environment variables.
#
# This file IS committed to Git.
# It shows teammates what variables they need WITHOUT exposing real secrets.
#
# Setup:
#   cp .env.example .env
#   Then fill in your actual values in .env

APP_NAME=Todo API
DEBUG=True
DATABASE_URL=sqlite:///./todo.db
API_V1_PREFIX=/api/v1

# Future auth variables (uncomment when you add authentication):
# SECRET_KEY=your-super-secret-key-here-change-this
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# Future PostgreSQL (uncomment when switching from SQLite):
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/todo_db
